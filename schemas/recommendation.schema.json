{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Recommendation",
  "type": "object",
  "required": ["id","softwareId","useCaseId","rationale","sourceReferences","evidenceIds","trustScore"],
  "properties": {
    "id": {"type":"string"},
    "softwareId": {"type":"string"},
    "useCaseId": {"type":"string"},
    "rationale": {"type":"string"},
    "sourceReferences": {"type":"array","minItems":1,"items":{"type":"string"}},
    "evidenceIds": {"type":"array","minItems":1,"items":{"type":"string"}},
    "trustScore": {"type":"number","minimum":0,"maximum":100}
  }
}
