{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnchorTotem",
  "type": "object",
  "additionalProperties": false,
  "required": ["totemId", "totemType", "owner", "mission", "principles", "restraints", "status", "lastReviewedAt"],
  "properties": {
    "totemId": { "type": "string", "minLength": 1 },
    "totemType": { "const": "anchor" },
    "owner": { "type": "string", "minLength": 1 },
    "mission": { "type": "string", "minLength": 1 },
    "principles": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "restraints": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "edgeWarnings": { "type": "array", "items": { "type": "string" } },
    "memoryRefs": { "type": "array", "items": { "type": "string" } },
    "authorityRefs": { "type": "array", "items": { "type": "string" } },
    "status": { "enum": ["active", "review_required", "stale", "superseded", "retired"] },
    "lastReviewedAt": { "type": "string", "format": "date-time" }
  }
}
