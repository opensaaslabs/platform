{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EdgeExit",
  "type": "object",
  "required": [
    "exitId",
    "owner",
    "intent",
    "audience",
    "evidenceRefs",
    "conformanceStatus",
    "policyStatus",
    "ipStatus",
    "traceId",
    "timestamp",
    "correctionPath"
  ],
  "properties": {
    "exitId": {"type":"string"},
    "owner": {"type":"string"},
    "intent": {"type":"string"},
    "audience": {"type":"string"},
    "evidenceRefs": {"type":"array","minItems":1,"items":{"type":"string"}},
    "conformanceStatus": {"enum":["passing","warning","failing"]},
    "policyStatus": {"enum":["allowed","requires_review","blocked"]},
    "ipStatus": {"enum":["original","licensed","public_domain","fair_use_reviewed","permission_granted","unknown"]},
    "traceId": {"type":"string"},
    "timestamp": {"type":"string","format":"date-time"},
    "correctionPath": {"type":"string"}
  }
}
