{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensaaslabs.org/schemas/use-case.schema.json",
  "title": "Use Case",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "description", "category", "audience", "maturityLevel"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "audience": { "enum": ["individual", "startup", "smb", "mid-market", "enterprise", "public-sector", "education"] },
    "maturityLevel": { "enum": ["beginner", "emerging", "scaling", "managed", "optimized"] },
    "recommendedCapabilities": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "successMetrics": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
